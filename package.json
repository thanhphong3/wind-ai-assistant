{
  "name": "wind-agent-assistant",
  "displayName": "Wind Agent Coding Assistant",
  "description": "AI coding assistant.",
  "version": "0.0.8",
  "publisher": "PhamThanhPhong",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": "https://github.com/thanhphong3/wind-ai-assistant",
  "homepage": "https://github.com/thanhphong3/wind-ai-assistant",
  "bugs": "https://github.com/thanhphong3/wind-ai-assistant/issues",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:wind-agent.chatView",
    "onCommand:wind-agent.clearChat",
    "onCommand:wind-agent.showHistory",
    "onCommand:wind-agent.showSettings",
    "onCommand:wind-agent.pinSelectionToChat",
    "onCommand:wind-agent.inlineEdit",
    "onCommand:wind-agent.openInBrowser",
    "onCommand:wind-agent.openConfig"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wind-agent-sidebar",
          "title": "Wind",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "wind-agent-sidebar": [
        {
          "type": "webview",
          "id": "wind-agent.chatView",
          "name": "Wind"
        }
      ]
    },
    "commands": [
      {
        "command": "wind-agent.clearChat",
        "title": "New Chat",
        "icon": "$(add)"
      },
      {
        "command": "wind-agent.showHistory",
        "title": "History",
        "icon": "$(history)"
      },
      {
        "command": "wind-agent.showSettings",
        "title": "Settings",
        "icon": "$(gear)"
      },
      {
        "command": "wind-agent.pinSelectionToChat",
        "title": "Pin Selection to Chat"
      },
      {
        "command": "wind-agent.inlineEdit",
        "title": "Inline Edit Selection"
      },
      {
        "command": "wind-agent.openInBrowser",
        "title": "Open in Browser"
      },
      {
        "command": "wind-agent.openConfig",
        "title": "Open Config (ai_config.json)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "wind-agent.clearChat",
          "when": "view == wind-agent.chatView",
          "group": "navigation@1"
        },
        {
          "command": "wind-agent.showHistory",
          "when": "view == wind-agent.chatView",
          "group": "navigation@2"
        },
        {
          "command": "wind-agent.showSettings",
          "when": "view == wind-agent.chatView",
          "group": "navigation@3"
        }
      ],
      "explorer/context": [
        {
          "command": "wind-agent.openInBrowser",
          "when": "resourceExtname == .html",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "wind-agent.openInBrowser",
          "when": "resourceLangId == html",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Wind Settings",
      "properties": {
        "windAgent.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for the LLM Provider."
        },
        "windAgent.apiEndpoint": {
          "type": "string",
          "default": "https://generativelanguage.googleapis.com/v1beta/openai",
          "description": "API Endpoint URL (e.g. OpenAI compatible endpoint)."
        },
        "windAgent.model": {
          "type": "string",
          "default": "gemini-3.5-flash",
          "description": "Model to use for agent interactions."
        },
        "windAgent.autoExecution": {
          "type": "string",
          "default": "Ask for Approval",
          "enum": [
            "Ask for Approval",
            "Always Proceed"
          ],
          "description": "Auto Execution Policy for Agent. If 'Always Proceed', commands and file modifications are run without asking for approval."
        },
        "windAgent.autoExecutePlan": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start executing the plan after generating it."
        },
        "windAgent.browser": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "chrome",
            "edge",
            "firefox"
          ],
          "enumDescriptions": [
            "Auto Detect (Chrome, then Edge, then Firefox)",
            "Google Chrome",
            "Microsoft Edge",
            "Mozilla Firefox"
          ],
          "description": "Preferred browser for running web automation and testing."
        },
        "windAgent.enableInlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable inline code completions (ghost text) as you type."
        },
        "windAgent.inlineCompletionModel": {
          "type": "string",
          "default": "gemini-3.5-flash",
          "description": "Select the model specifically used for inline completions."
        },
        "windAgent.inlineCompletionTimeout": {
          "type": "integer",
          "default": 30000,
          "description": "Timeout in milliseconds for inline code completion requests. Increase this if using slow or local models."
        }
      }
    },
    "keybindings": [
      {
        "command": "wind-agent.pinSelectionToChat",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorHasSelection"
      },
      {
        "command": "wind-agent.inlineEdit",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tsc": "tsc -p ./",
    "watch-tsc": "tsc -watch -p ./",
    "vsce-package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.27.0",
    "ts-loader": "^9.6.2",
    "typescript": "^5.3.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "puppeteer-core": "^22.6.0"
  }
}
